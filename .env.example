# Connection strings de PostgreSQL (Supabase), usados por Prisma (server-side, funciones en /api).
# Se sacan del panel de Supabase: Project Settings → Database → Connection string.
#
# DATABASE_URL: pooler de conexiones (PgBouncer, puerto 6543) — la usan las funciones
# serverless de /api en runtime. Agregá "?pgbouncer=true" al final.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: conexión directa (puerto 5432) — la usa el Prisma CLI para `db push` /
# migraciones (el pooler en modo transaction no soporta lo que Prisma necesita para eso).
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:password@aws-0-region.pooler.supabase.com:5432/postgres"

# URL base de la API vista desde el navegador. Dejar sin definir en desarrollo
# (usa "/api", mismo origen) y en producción en Vercel (mismo origen también).
# Solo se necesita si el frontend y el backend viven en dominios distintos.
# VITE_API_URL=https://tu-deploy.vercel.app/api
