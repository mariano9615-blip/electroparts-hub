# Connection string de MySQL, usado por Prisma (server-side, funciones en /api).
# Formato: mysql://usuario:password@host:puerto/nombre_db?sslaccept=strict
# Con TiDB Cloud Serverless / PlanetScale / Railway, copiá el connection string
# que te da el panel del proveedor (ver guía en ANTIGRAVITY.md).
DATABASE_URL="mysql://usuario:password@host:4000/electroparts?sslaccept=strict"

# URL base de la API vista desde el navegador. Dejar sin definir en desarrollo
# (usa "/api", mismo origen) y en producción en Vercel (mismo origen también).
# Solo se necesita si el frontend y el backend viven en dominios distintos.
# VITE_API_URL=https://tu-deploy.vercel.app/api
